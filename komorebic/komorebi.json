{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.42/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",

  "transparency": true,
  "transparency_alpha": 252,
  "default_workspace_padding": 2,
  "default_container_padding": 3,
  "border": false,
  "border_style": "Rounded",
  "border_width": 4,
  "border_offset": -1,
  "mouse_follows_focus": false,

  "animation": {
    "enabled": true,
    "duration": 160,
    "fps": 300,
    "style": {
      "movement": "EaseInOutQuad",
      "transparency": "Linear"
    }
  },

  "border_colours": {
    "single": "#4b775e",
    "unfocused": "#6d9471",
    "floating": "#4b775e",
    "monocle": "#6d9471"
  },

  "monitors": [
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "BSP"
        },
        {
          "name": "II",
          "layout": "Grid"
        },
        {
          "name": "III",
          "layout": "UltrawideVerticalStack"
        }
      ]
    },
    {
      "workspaces": [
        {
          "name": "Home",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "Grid"
        },
        {
          "name": "3",
          "layout": "UltrawideVerticalStack"
        }
      ]
    }
  ],

  "ignore_rules": [
    {
      "kind": "Exe",
      "id": "ACShadows.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Overwatch.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Photos.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "explorer.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "PotPlayerMini64.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "AmneziaVPN.exe",
      "matching_strategy": "Equals"
    }
  ]
}